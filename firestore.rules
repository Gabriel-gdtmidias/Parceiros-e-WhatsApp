rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: clients
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required) - The name of the client.
    //   - createdAt: timestamp (required) - When the client was added.
    //   - uid: string (required) - The user ID who owns this client.
    //
    // Collection: histories
    // Document ID: auto-generated
    // Fields:
    //   - clientId: string (required) - The ID of the client this history belongs to.
    //   - mode: string (required) - The type of summary generated.
    //   - content: string (required) - The generated summary content.
    //   - createdAt: timestamp (required) - When the history was generated.
    //   - uid: string (required) - The user ID who owns this history.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidClient(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.createdAt is timestamp &&
             data.uid is string && data.uid == request.auth.uid;
    }

    function isValidHistory(data) {
      return data.clientId is string &&
             data.mode in ['communication', 'account_actions', 'group_update', 'client_response'] &&
             data.content is string && data.content.size() > 0 &&
             data.createdAt is timestamp &&
             data.uid is string && data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /clients/{clientId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidClient(request.resource.data);
      allow update: if isDocOwner() && isValidClient(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }

    match /histories/{historyId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidHistory(request.resource.data);
      allow update: if isDocOwner() && isValidHistory(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner();
    }
  }
}
